# ===========================================
# SiteChat Configuration
# Copy this file to .env and configure as needed
# ===========================================

# App Settings
APP_NAME=SiteChat
DEBUG=false
ENVIRONMENT=production  # Options: development, staging, production

# ===========================================
# Security Settings
# ===========================================

# CORS - comma-separated list of allowed origins
# Use * for development only, specify domains in production
CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
CORS_ALLOW_CREDENTIALS=true

# Trusted hosts (for reverse proxy setups)
TRUSTED_HOSTS=yourdomain.com,www.yourdomain.com

# Enable security headers (X-Frame-Options, CSP, etc.)
ENABLE_SECURITY_HEADERS=true

# ===========================================
# LLM Provider Configuration
# Options: ollama, openai, anthropic, azure
# ===========================================
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# Ollama (default - runs locally)
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI (if using openai provider)
# OPENAI_API_KEY=sk-xxx

# Anthropic (if using anthropic provider)
# ANTHROPIC_API_KEY=sk-ant-xxx

# Azure OpenAI (if using azure provider)
# AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com/
# AZURE_OPENAI_API_KEY=xxx
# AZURE_OPENAI_DEPLOYMENT=gpt-4

# ===========================================
# Embeddings Provider Configuration
# Options: huggingface, openai, ollama
# ===========================================
EMBEDDINGS_PROVIDER=huggingface
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# ===========================================
# Vector Store Provider Configuration
# Options: faiss, chroma, pinecone, qdrant
# ===========================================
VECTOR_STORE_PROVIDER=faiss
FAISS_INDEX_PATH=./data/faiss_index

# Chroma
# CHROMA_PERSIST_DIR=./data/chroma_db
# CHROMA_COLLECTION_NAME=sitechat_docs

# Pinecone (if using pinecone provider)
# PINECONE_API_KEY=xxx
# PINECONE_INDEX=sitechat
# PINECONE_ENVIRONMENT=us-east1-gcp

# Qdrant (if using qdrant provider)
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=xxx
# QDRANT_COLLECTION=sitechat

# ===========================================
# Database Provider Configuration
# Options: mongodb, postgresql (coming soon)
# ===========================================
DATABASE_PROVIDER=mongodb
MONGODB_URL=mongodb+srv://root:pX4L2!2!pX4L2!!qZqZ@sitechat.cap7o4w.mongodb.net/?appName=SiteChat
MONGODB_DB=SiteChat

# PostgreSQL (coming soon)
# POSTGRESQL_URL=postgresql://user:pass@localhost:5432/sitechat

# ===========================================
# Storage Provider Configuration
# Options: local, s3, gcs (coming soon)
# ===========================================
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./data/uploads

# S3 (coming soon)
# S3_BUCKET=sitechat-uploads
# S3_REGION=us-east-1
# S3_ACCESS_KEY=xxx
# S3_SECRET_KEY=xxx

# GCS (coming soon)
# GCS_BUCKET=sitechat-uploads
# GCS_CREDENTIALS_PATH=./gcs-credentials.json

# ===========================================
# Cache Provider Configuration
# Options: memory, redis (coming soon)
# ===========================================
CACHE_PROVIDER=memory
CACHE_TTL=300

# Redis (coming soon)
# REDIS_URL=redis://localhost:6379

# ===========================================
# Authentication
# ===========================================
# IMPORTANT: Generate a strong secret for production!
# Use: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GENERATE-A-64-CHARACTER-SECRET-KEY-HERE
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Initial admin credentials (created on first run if no admin exists)
# Set ADMIN_PASSWORD to empty to disable auto-creation and create admin via API
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStr0ng!Passw0rd

# Password policy
MIN_PASSWORD_LENGTH=8
REQUIRE_PASSWORD_COMPLEXITY=true

# ===========================================
# RAG Settings
# ===========================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5

# ===========================================
# Crawler Settings
# ===========================================
MAX_PAGES=100
CRAWL_DELAY=1.0

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW=60

# ===========================================
# Conversation Settings
# ===========================================
CONVERSATION_WINDOW_SIZE=10
